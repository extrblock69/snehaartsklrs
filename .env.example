# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ------------- STANDALONE BACKEND ON RENDER SETUP -------------
# FRONTEND_URL: The URL of your Vercel-hosted frontend (e.g., https://snehaartsklrs.vercel.app).
# Securely configures CORS so only requests originating from your frontend will be handled.
FRONTEND_URL=

# BACKEND_URL: The URL of your Render-hosted backend (e.g., https://sneha-art-backend.onrender.com).
# Used to respond with absolute URLs for uploaded images, avoiding domain mismatches.
BACKEND_URL=

# PORT: The port your Render Express server runs on. Render automatically injects this.
PORT=3000

# ------------- VERCEL STATIC FRONTEND SETUP -------------
# VITE_API_URL: The URL of your Render-hosted backend (e.g., https://sneha-art-backend.onrender.com).
# Place this variable inside your Vercel project environment configuration.
# If omitted during local dev, the app resolves dynamically to relative localhost APIs.
VITE_API_URL=

# ADMIN PANEL CREDENTIALS:
# Default values will be used if left blank (Username: admin, Password: sneha_admin_2026).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=sneha_admin_2026

# RESEND.COM EMAIL NOTIFICATIONS INTEGRATION
# Set these variables to securely route front-end contact submissions directly to the administrator's email.
# Your resend.com API Key (starting with re_...)
RESEND_API_KEY=
# Who receives the contact form inquiries (e.g., your admin email pinedaguarama25@gmail.com)
RESEND_TO_EMAIL=
# Verified domain sender address in Resend. Free tiers can use the default resend onboarding sender.
RESEND_FROM_EMAIL=Drawing Inquiry <onboarding@resend.dev>

# OPTIONAL SUPABASE INTEGRATION (FOR PERSISTENT CLOUD DATABASE & CLOUD STORAGE):
# If provided, all text, media uploads, and portfolio configurations will persist in the cloud permanently.
# 1. SUPABASE_URL: Your Supabase Project API URL (found in Project Settings -> API)
SUPABASE_URL=

# 2. SUPABASE_ANON_KEY: Your Supabase Anon/Public API Key (found in Project Settings -> API)
SUPABASE_ANON_KEY=

# 3. SUPABASE_STORAGE_BUCKET: The name of the bucket created in Supabase Storage (e.g., 'portfolio').
# Ensure the bucket is public so image URLs are accessible to visitors without authentication.
SUPABASE_STORAGE_BUCKET=portfolio

