# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ------------- STANDALONE BACKEND ON RENDER SETUP -------------
# FRONTEND_URL: The URL of your Vercel-hosted frontend (e.g., https://snehaartsklrs.vercel.app).
# Securely configures CORS so only requests originating from your frontend will be handled.
FRONTEND_URL=

# BACKEND_URL: The URL of your Render-hosted backend (e.g., https://sneha-art-backend.onrender.com).
# Used to respond with absolute URLs for uploaded images, avoiding domain mismatches.
BACKEND_URL=

# PORT: The port your Render Express server runs on. Render automatically injects this.
PORT=3000

# ------------- VERCEL STATIC FRONTEND SETUP -------------
# VITE_API_URL: The URL of your Render-hosted backend (e.g., https://sneha-art-backend.onrender.com).
# Place this variable inside your Vercel project environment configuration.
# If omitted during local dev, the app resolves dynamically to relative localhost APIs.
VITE_API_URL=

# ADMIN PANEL CREDENTIALS:
# Default values will be used if left blank (Username: admin, Password: sneha_admin_2026).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=sneha_admin_2026

# OPTIONAL SUPABASE INTEGRATION (FOR PERSISTENT CLOUD DATABASE):
# If provided, all text, image, and schedule edits will sync to Supabase.
# Otherwise, safe file-based backend persistence (site_content.json) is used automatically.
SUPABASE_URL=
SUPABASE_KEY=

